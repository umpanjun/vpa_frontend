# Stage 1: Build
FROM node:20 as build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

# 🔴 บังคับฝัง URL พอร์ต 3001 ลงไปเฉพาะในตู้เทสนี้เท่านั้น
RUN echo "VITE_API_BASE=http://147.50.253.67:3001" > .env
RUN echo "VITE_API_BASE=http://147.50.253.67:3001" > .env.production
RUN echo "VITE_WITH_CREDENTIALS=true" >> .env
RUN echo "VITE_WITH_CREDENTIALS=true" >> .env.production

# 🔴 สั่งสลับชื่อ backend ใน nginx.conf ให้กลายเป็นตัวเทส
RUN sed -i 's/vpa_backend:3000/vpa_backend_test:3000/g' nginx.conf

RUN npm run build

# Stage 2: Serve
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY --from=build /app/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80